+def test_arxiv_version_comparison_mechanics():
+    """T-20260713-001: the comparison itself, offline. A revision fires a
+    mechanical record (id, cached version, latest version); an unchanged
+    version is silence, not noise."""
+    from universe_explorer.dataops.source_health import _version_findings
+    cached = {"2111.03606": 4, "1207.3123": 2}
+
+    # unchanged -> zero events, zero noise
+    assert _version_findings(cached, {"2111.03606": 4, "1207.3123": 2}) == []
+
+    # one revised -> exactly one finding, carrying id + old + new
+    out = _version_findings(cached, {"2111.03606": 5, "1207.3123": 2})
+    assert len(out) == 1
+    f = out[0]
+    assert f["source_doi"] == "arXiv:2111.03606"
+    assert f["updating_doi"] == "arXiv:2111.03606v5"
+    assert f["title"] == "cached v4 -> latest v5"
+    assert f["update_types"] == ["new_arxiv_version"]
+    # zero interpretation: same mechanical schema as Crossref findings
+    assert set(f) == {"source_doi", "updating_doi", "update_types",
+                      "title", "issued"}
+
+
+def test_arxiv_unknown_versions_stay_silent():
+    """0 = version unknown/unparsable. The machine records what it can prove;
+    it never guesses — unknown on either side must not fire."""
+    from universe_explorer.dataops.source_health import _version_findings
+    assert _version_findings({"a": 0}, {"a": 3}) == []
+    assert _version_findings({"a": 2}, {"a": 0}) == []
+    assert _version_findings({"a": 2}, {}) == []
+    # and a DOWNgrade (api hiccup) is not "a new version" either
+    assert _version_findings({"a": 3}, {"a": 2}) == []
+
+
