+def _version_findings(cached: Dict[str, int], current: Dict[str, int]) -> List[dict]:
+    """The pure comparison: cached-at-fetch-time versions vs the live latest.
+    0 means "version unknown / unparsable" and stays silent on either side —
+    the machine records what it can prove, it never guesses. Separated from
+    the network fetch so the mechanics are testable offline."""
+    findings = []
+    for a in sorted(cached):
+        cur = current.get(a, 0)
+        if cur and cached.get(a, 0) and cur > cached[a]:
+            findings.append({
+                "source_doi": f"arXiv:{a}",
+                # ack key, same mechanism as Crossref updates:
+                "updating_doi": f"arXiv:{a}v{cur}",
+                "update_types": ["new_arxiv_version"],
+                "title": (f"cached v{cached[a]} -> latest v{cur}"),
+                "issued": [None],
+            })
+    return findings
+
